{
	"private": true,
	"name": "image-downloader",
	"version": "4.2.0",
	"license": "GPLv3",
	"scripts": {
		"dev": "bun start",
		"start": "bun run build && bun scripts/watch.js",
		"build": "bun scripts/build.js && bun run build:zip",
		"build:zip": "rm -f ../image-downloader.zip && cd build && zip -r ../../image-downloader.zip .",
		"task": "bun scripts/task.js",
		"test": "bun test",
		"lint": "bunx prettier --write ."
	},
	"devDependencies": {
		"@tailwindcss/cli": "4.2.2",
		"@types/bun": "1.3.11",
		"@types/chrome": "0.0.315",
		"@types/jquery": "3.5.1",
		"fs-extra": "9.0.1",
		"glob": "7.1.6",
		"glob-watcher": "5.0.5",
		"happy-dom": "20.8.7",
		"prettier": "3.5.3",
		"prettier-plugin-organize-imports": "4.3.0",
		"prettier-plugin-tailwindcss": "0.7.2",
		"react": "18.3.1",
		"react-dom": "18.3.1",
		"sharp": "0.34.1",
		"sneer": "1.0.1",
		"tailwindcss": "4.2.2",
		"typescript": "5.8.3"
	}
}
